/*
 * =============================================================================
 * nf-TTISS — Pipeline Configuration
 * =============================================================================
 *
 * Profiles:
 *   standard     — local execution, no containers
 *   docker       — per-process Docker containers 
 *   local_docker — single all-in-one nf-ttiss:latest image (built from Dockerfile)
 *  
 *
 * Override any parameter on the CLI with --<param> <value>.
 * =============================================================================
 */

// Global default params
params {
    // Input/Output
    reads = "data/*_R{1,2}.fastq.gz"
    outdir = "results"
    
    // Cutadapt primer filtering parameters
    primer = "^NNNNNNNNNNNNNNNNNCGC"  // 17 random bases (UMI) + CGC
    error_rate = 0.1
    min_length = 40
    quality_cutoff = 20
    
    // BWA mapping parameters
    reference = "ref/hg19_chr8.fa"
    
    // MAPQ filter for EXTRACT_WINDOWS (20 = uniquely mapped; 0 = keep all)
    mapq = 20
    
    // Maximum insert size — discard pairs where R1 and R2 map >max_insert bp apart
    max_insert = 1000
    
    // Resource defaults
    max_memory = '8.GB'
    max_cpus = 2
    max_time = '24.h'
}

// Process configuration
process {
    // Default resources for all processes
    cpus = 2
    memory = '4.GB'
    time = '2.h'
    
    // Process-specific resources
    withName: FASTQC {
        cpus = 2
        memory = '2.GB'
        time = '1.h'
    }
    
    withName: MULTIQC {
        cpus = 1
        memory = '2.GB'
        time = '30.m'
    }
    
    withName: CUTADAPT {
        cpus = 2
        memory = '4.GB'
        time = '4.h'
    }
    
    withName: TRIM_AND_TRUNCATE {
        cpus = 2
        memory = '4.GB'
        time = '2.h'
    }
    
    withName: BWA_MAP {
        cpus = 2
        memory = '4.GB'
        time = '4.h'
    }
    
    withName: EXTRACT_WINDOWS {
        cpus = 2
        memory = '4.GB'
        time = '2.h'
    }
    
    withName: MATCH_GUIDES {
        cpus = 2
        memory = '4.GB'
        time = '1.h'
    }
}

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }
    
    docker {
        docker.enabled = true
        process {
            withName: FASTQC {
                container = 'nf-ttiss:latest'
            }
            withName: MULTIQC {
                container = 'nf-ttiss:latest'
            }
            withName: CUTADAPT {
                container = 'nf-ttiss:latest'
            }
            withName: TRIM_AND_TRUNCATE {
                container = 'nf-ttiss:latest'
            }
            withName: BWA_MAP {
                container = 'nf-ttiss:latest'
            }
            withName: MAPPING_SUMMARY {
                container = 'nf-ttiss:latest'
            }
            withName: EXTRACT_WINDOWS {
                container = 'nf-ttiss:latest'
            }
            withName: MATCH_GUIDES {
                container = 'nf-ttiss:latest'
            }
        }
    }
    


    // Single all-in-one image — use after: docker build -t nf-ttiss:latest .
    local_docker {
        docker.enabled = true
        docker.runOptions = '-v /workspaces:/workspaces'
        process.container = 'nf-ttiss:latest'
        process.stageInMode = 'copy'
    }
}

// Report configuration
report {
    enabled = true
    file = "${params.outdir}/reports/execution_report.html"
}

timeline {
    enabled = true
    file = "${params.outdir}/reports/timeline.html"
}

trace {
    enabled = true
    file = "${params.outdir}/reports/trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/reports/dag.html"
}

// Manifest
manifest {
    name            = 'nf-TTISS'
    author          = 'Frederick Mappin'
    description     = 'Targeted Transgene Integration Site Sequencing pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.0.0'
    version         = '1.0.0'
}
